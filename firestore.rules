rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isSelf(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function workspaceExists(workspaceId) {
      return exists(/databases/$(database)/documents/workspaces/$(workspaceId));
    }

    function workspaceDoc(workspaceId) {
      return get(/databases/$(database)/documents/workspaces/$(workspaceId));
    }

    function memberDocPath(workspaceId) {
      return /databases/$(database)/documents/workspaces/$(workspaceId)/members/$(request.auth.uid);
    }

    function hasMemberDoc(workspaceId) {
      return isSignedIn() && exists(memberDocPath(workspaceId));
    }

    function isInMemberUids(data) {
      return data.keys().hasAll(['memberUids'])
        && request.auth.uid in data.memberUids;
    }

    function isWorkspaceMember(workspaceId) {
      return isSignedIn() && (
        hasMemberDoc(workspaceId)
        || (workspaceExists(workspaceId) && isInMemberUids(workspaceDoc(workspaceId).data))
      );
    }

    function isWorkspaceCreator(workspaceId) {
      return isSignedIn()
        && workspaceExists(workspaceId)
        && workspaceDoc(workspaceId).data.createdBy == request.auth.uid;
    }

    function canAccessWorkspace(workspaceId) {
      return isWorkspaceMember(workspaceId) || isWorkspaceCreator(workspaceId);
    }

    function isWorkspaceOwner(workspaceId) {
      return hasMemberDoc(workspaceId)
        && get(memberDocPath(workspaceId)).data.role == 'owner';
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/chats/$(chatId))
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.members;
    }

    // ─── Users ───────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isSignedIn();
      allow create, update: if isSelf(uid);
      allow delete: if false;

      match /fcmTokens/{tokenId} {
        allow read, write: if isSelf(uid);
      }

      match /blocked/{blockedUid} {
        allow read, write: if isSelf(uid);
      }
    }

    // ─── Workspaces ─────────────────────────────────────────────────────────
    match /workspaces/{workspaceId} {
      allow read: if isSignedIn();

      allow create: if isSignedIn()
        && request.resource.data.createdBy == request.auth.uid
        && request.auth.uid in request.resource.data.memberUids
        && request.resource.data.inviteCode is string
        && request.resource.data.name is string;

      // Members can update; new users can join (add themselves to memberUids).
      allow update: if isSignedIn() && (
        isInMemberUids(resource.data)
        || isInMemberUids(request.resource.data)
      );

      allow delete: if isSignedIn() && resource.data.createdBy == request.auth.uid;

      match /members/{memberId} {
        allow read: if isSignedIn() && (
          request.auth.uid == memberId
          || canAccessWorkspace(workspaceId)
        );
        allow create: if isSignedIn() && request.auth.uid == memberId;
        allow update: if isSelf(memberId) && canAccessWorkspace(workspaceId);
        allow delete: if false;
      }

      match /channels/{channelId} {
        allow read: if canAccessWorkspace(workspaceId);

        allow create: if isSignedIn()
          && request.resource.data.createdBy == request.auth.uid
          && request.resource.data.type == 'text'
          && request.resource.data.name is string
          && canAccessWorkspace(workspaceId);

        allow update: if canAccessWorkspace(workspaceId);
        allow delete: if isWorkspaceOwner(workspaceId);

        match /messages/{messageId} {
          allow read: if canAccessWorkspace(workspaceId);
          allow create: if canAccessWorkspace(workspaceId)
            && request.resource.data.senderUid == request.auth.uid;
          allow update: if canAccessWorkspace(workspaceId);
          allow delete: if canAccessWorkspace(workspaceId);
        }

        match /typing/{uid} {
          allow read: if canAccessWorkspace(workspaceId);
          allow write: if isSelf(uid) && canAccessWorkspace(workspaceId);
        }
      }
    }

    // ─── Direct chats ───────────────────────────────────────────────────────
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.members;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.members
        && request.resource.data.members.size() == 2;

      allow update: if isChatMember(chatId);
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if isChatMember(chatId);
        allow create: if isChatMember(chatId)
          && request.resource.data.senderUid == request.auth.uid;
        allow update: if isChatMember(chatId);
        allow delete: if isChatMember(chatId);
      }

      match /typing/{uid} {
        allow read: if isChatMember(chatId);
        allow write: if isSelf(uid) && isChatMember(chatId);
      }
    }

    // ─── Notifications ──────────────────────────────────────────────────────
    match /notifications/{notificationId} {
      allow read: if isSignedIn() && resource.data.toUid == request.auth.uid;

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.seen == false;

      allow update: if isSignedIn() && resource.data.toUid == request.auth.uid;

      allow delete: if false;
    }

    // ─── Friends ──────────────────────────────────────────────────────────────
    match /friend_requests/{requestId} {
      allow read: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid
        || resource.data.toUid == request.auth.uid
      );

      allow create: if isSignedIn()
        && request.resource.data.fromUid == request.auth.uid
        && request.resource.data.toUid is string
        && request.resource.data.status == 'pending';

      allow update: if isSignedIn() && (
        resource.data.fromUid == request.auth.uid
        || resource.data.toUid == request.auth.uid
      );

      allow delete: if false;
    }

    match /friendships/{friendshipId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.users;

      allow create: if isSignedIn()
        && request.auth.uid in request.resource.data.users
        && request.resource.data.users.size() == 2;

      allow update: if false;
      allow delete: if isSignedIn() && request.auth.uid in resource.data.users;
    }
  }
}
